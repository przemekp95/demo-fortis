{
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "generate:api-types": "openapi-typescript ../../docs/openapi/v1.yaml --output resources/js/types/public-api.d.ts && prettier --write resources/js/types/public-api.d.ts",
        "check:api-types": "tmp=resources/js/types/.public-api.check.d.ts && trap 'rm -f \"$tmp\"' EXIT && openapi-typescript ../../docs/openapi/v1.yaml --output \"$tmp\" >/dev/null && prettier --config .prettierrc --parser typescript --write \"$tmp\" >/dev/null && diff -u resources/js/types/public-api.d.ts \"$tmp\"",
        "lint": "eslint resources/js --ext .js,.vue",
        "format:check": "prettier --check resources/js",
        "test:unit": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^1.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vitest/coverage-v8": "^4.0.18",
        "autoprefixer": "^10.4.12",
        "axios": "^1.1.2",
        "eslint": "^8.57.1",
        "eslint-plugin-vue": "^9.30.0",
        "laravel-vite-plugin": "^2.1.0",
        "lodash": "^4.17.19",
        "openapi-typescript": "^7.13.0",
        "postcss": "^8.4.18",
        "prettier": "^3.3.3",
        "tailwindcss": "^3.2.1",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "vue": "^3.2.41",
        "ziggy-js": "^2.6.2"
    },
    "overrides": {
        "flatted": "^3.4.1"
    }
}
